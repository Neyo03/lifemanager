@using LifeManager.Data
@using LifeManager.Model
@using LifeManager.State
@inject TagModalStateService ModalService

<div class="drawer drawer-end">
    <input id="my-drawer-1" type="checkbox" class="drawer-toggle" checked="@IsOpen" readonly />

    <div class="drawer-side">
        <label for="my-drawer-1" class="drawer-overlay" @onclick="OnClose"></label>
        <div class="menu bg-base-100 min-h-full w-1/3 p-4">
            
            <h2 class="text-2xl mb-4">@(IsEditMode ? $"Edit {CurrentTask.Title}" : "Add Task")</h2>
            
            <span  class="text-xs link  text-error/50" @onclick="OnDelete"> Supprimer</span>
            
            <EditForm Model="CurrentTask" OnValidSubmit="OnSave" class="col-10 mt-5 w-full">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <label class="floating-label"> 
                    <span>Room</span>
                    <InputSelect class="select" @bind-Value="CurrentTask.Room.Id">
                        <option value="">Select a room</option>
                        @if (Rooms != null)
                        {
                            @foreach (var room in Rooms)
                            {
                                <option value="@room.Id">@room.Name</option>
                            }
                        }
                    </InputSelect>
                </label>
                <ValidationMessage For="() => CurrentTask.Room"/>

                <label class="floating-label mt-3">
                    <span>Title</span>
                    <InputText class="input input-ghost" @bind-Value="CurrentTask.Title"/>
                </label>
                <ValidationMessage For="() => CurrentTask.Title"/>
                
                <label class="floating-label mt-3">
                    <span>Description</span>
                    <InputTextArea rows="3" class="textarea border-transparent" @bind-Value="CurrentTask.Description"></InputTextArea>
                </label>

                <div class="flex flex-col gap-2 mt-3 text-xs w-1/2">
                    <div class="flex gap-8 items-center">
                        <span class="label w-1/5">Due Date</span>
                        <InputDate class="input input-ghost input-xs" @bind-Value="CurrentTask.DueDate" />
                    </div>
                    
                    <div class="flex gap-8 items-start mt-2">
                        <span class="label w-1/5">Tags</span>
                        <div class="flex flex-wrap items-center gap-2">
                            
                            @foreach (var taskTag in CurrentTask.Tags)
                            {
                                <span class="badge badge-xs cursor-pointer group flex items-center gap-1 transition-all text-white border-none" 
                                      style="background-color: @taskTag.ColorHex" 
                                      @onclick="() => RemoveTaskTag(taskTag)">
    
                                    @taskTag.Label
    
                                    <svg class="w-3 h-3 hidden group-hover:block text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                    </svg>
                                </span>
                            }
                            
                            <button type="button" class="badge badge-xs badge-dash badge-info cursor-pointer" popovertarget="popovertags" style="anchor-name:--anchor-1">
                                + Tag
                            </button>
                        </div>
                        
                        <ul class="dropdown menu w-52 rounded-box bg-base-100 shadow-sm text-xs p-2" popover id="popovertags" style="position-anchor:--anchor-1">
                            
                            <li class="mb-2">
                                <label class="input input-xs flex items-center gap-2">
                                    <svg class="h-[1em] opacity-50" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                                        <g stroke-linejoin="round" stroke-linecap="round" stroke-width="2.5" fill="none" stroke="currentColor">
                                            <circle cx="11" cy="11" r="8"></circle>
                                            <path d="m21 21-4.3-4.3"></path>
                                        </g>
                                    </svg>
                                    <input type="search" placeholder="Search..." @bind="TagSearchQuery" @bind:event="oninput" />
                                </label>
                            </li>
                            
                            <li><a class="cursor-pointer font-bold text-primary" @onclick="ModalService.Show">Create new tag</a></li>
                            <div class="divider mt-1 mb-1"></div>
                            
                            @foreach (var tag in FilteredTags)
                            {
                                <li>
                                    <span class="cursor-pointer relative" @onclick="() => AddTaskTag(tag)"> <span class="rightshape " style="background-color: @tag.ColorHex" ></span> @tag.Label</span>
                                </li>
                            }
                            
                            @if (!FilteredTags.Any())
                            {
                                <li class="text-center opacity-50 mt-2">No tags found</li>
                            }
                        </ul>
                        
                    </div>
                </div>

                <div class="modal-action mt-8">
                    <button type="button" class="btn btn-secondary btn-xs btn-soft w-1/2" @onclick="OnClose">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-soft btn-xs w-1/2">@(IsEditMode ? "Update" : "Save")</button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public bool IsEditMode { get; set; }
    [Parameter] public required HouseTask CurrentTask { get; set; }
    [Parameter] public List<Room>? Rooms { get; set; }
    [Parameter] public List<Tag>? Tags { get; set; }
    
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }
    
    private string TagSearchQuery { get; set; } = string.Empty;
    
    private IEnumerable<Tag> FilteredTags => Tags?
        .Where(t => !CurrentTask.Tags.Any(ct => ct.Id == t.Id))
        .Where(t => string.IsNullOrWhiteSpace(TagSearchQuery) || t.Label.Contains(TagSearchQuery, StringComparison.OrdinalIgnoreCase)) 
        ?? Array.Empty<Tag>();

    private void AddTaskTag(Tag tag)
    {
        CurrentTask.Tags.Add(tag);
        TagSearchQuery = string.Empty;
    }

    private void RemoveTaskTag(Tag tag)
    {
        var tagToRemove = CurrentTask.Tags.FirstOrDefault(t => t.Id == tag.Id);
        if (tagToRemove != null)
        {
            CurrentTask.Tags.Remove(tagToRemove);
        }
    }
}