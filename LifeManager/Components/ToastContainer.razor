@rendermode InteractiveServer
@implements IDisposable
@inject ToastService ToastService
@using LifeManager.State

<div class="toast toast-top toast-end z-100 pt-16 lg:pt-4">
    @foreach (var toast in ToastService.Messages)
    {

        <div @key="toast.Id" class="alert @GetAlertClass(toast.Type) shadow-lg flex items-center gap-3 text-white">
            <span class="text-sm">@toast.Message</span>
            <button class="btn btn-ghost btn-xs opacity-60" @onclick="() => ToastService.Dismiss(toast.Id)">✕</button>
        </div>
    }
</div>

@code {
    protected override void OnInitialized()
    {
        ToastService.OnChange += OnToastChanged;
}

    public void Dispose()
    {
        ToastService.OnChange -= OnToastChanged;
    }

    private void OnToastChanged() => InvokeAsync(StateHasChanged);

    private static string GetAlertClass(ToastType type) => type switch
    {
        ToastType.Success => "alert-success",
        ToastType.Error   => "alert-error",
        ToastType.Warning => "alert-warning",
        _                 => "alert-info",
    };
}
